{
  "uid": "puckzone-main",
  "title": "PuckZone — plataforma",
  "description": "Dashboard principal: disponibilidad, KPIs del enunciado (20 partidas simultáneas, <100ms, uptime 99%) y salud de la JVM por servicio.",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Servicios arriba (de 5)",
      "description": "Targets de Prometheus respondiendo /actuator/prometheus. El argumento de DISPONIBILIDAD: debe vivir en 5.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "count(up == 1) OR on() vector(0)", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 4 },
              { "color": "green", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Disponibilidad por servicio (up)",
      "description": "1 = el target respondió el último scrape; 0 = caído.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 18, "x": 6, "y": 0 },
      "targets": [{ "expr": "up", "legendFormat": "{{job}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Requests/s en el gateway (por ruta)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{job=\"gateway\"}[2m]))",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latencia del gateway p95 / p99",
      "description": "KPI del enunciado: <100ms. Latencia de TODO lo proxeado (histograma real, no promedio).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"gateway\"}[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"gateway\"}[5m])))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.1 }] }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Tick del game loop (ms)",
      "description": "KPI de ESCALABILIDAD de game: a 60Hz el presupuesto por tick es 16.6ms. Si el p99 se le acerca, el loop está saturado (las partidas bajan de frecuencia). La prueba de carga de 2026-07-14 mostró esto mismo con 0.5 vCPU.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "puckzone_game_tick_seconds{quantile=~\"0.5|0.95|0.99\"} * 1000",
          "legendFormat": "p{{quantile}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 16.6 }] }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Partidas en curso",
      "description": "KPI del enunciado: soportar 20 simultáneas.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "puckzone_game_rooms_playing", "legendFormat": "jugando", "refId": "A" },
        { "expr": "puckzone_game_rooms_paused", "legendFormat": "pausadas (gracia)", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "min": 0, "custom": { "fillOpacity": 20 } }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU del proceso por servicio",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [{ "expr": "process_cpu_usage", "legendFormat": "{{job}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Heap JVM usado por servicio",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "sum by (job) (jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Respuestas de control del gateway (401 / 423 / 429 / 5xx)",
      "description": "401 = sin token, 423 = bloqueo anti fuerza bruta de auth, 429 = rate limit, 5xx = errores.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{job=\"gateway\",status=~\"401|423|429|5..\"}[2m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } }, "overrides": [] }
    }
  ]
}
